{
	"name": "generathor",
	"version": "2.0.0",
	"description": "Generate files from templates and data sources automatically.",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git://github.com/generathor-js/generathor.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"author": "Diego Michelena Polo",
	"license": "MIT",
	"bin": {
		"generathor": "dist/runner.js"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"lint": "biome check . && eslint src/",
		"lint:fix": "biome check --write . && eslint src/ --fix",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepublishOnly": "bun run lint && bun run typecheck && bun run build",
		"release": "bun run build && npm publish",
		"prepare": "husky"
	},
	"keywords": [],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.19.0"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"args": "^5.0.3",
		"ejs": "^5.0.1",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/args": "^5.0.4",
		"@types/ejs": "^3.1.5",
		"@types/node": "22",
		"@vitest/coverage-v8": "^4.1.2",
		"bunup": "^0.16.31",
		"eslint": "^10.1.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.4.0",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"lint-staged": {
		"src/**/*.ts": [
			"biome check --write --no-errors-on-unmatched",
			"eslint --fix"
		]
	}
}
